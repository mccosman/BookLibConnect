# Coseman Web Design Plugin — Environment Variables
# Copy this file to ~/.config/gemini/.env and fill in your keys

# Google AI Studio / Gemini API Key
# Get free at: https://aistudio.google.com
# NOTE: New keys start with AQ. (not AIza...) — use gemini-2.5-flash model
GEMINI_API_KEY=AQ.your_key_here

# OpenAI API Key (optional — used as fallback if Gemini is unavailable)
# Note: OpenAI may be blocked in remote/cloud environments
OPENAI_API_KEY=sk-proj-your_key_here
